# MongoDB
MONGODB_URI="mongodb+srv://<user>:<password>@<host>/?retryWrites=true&w=majority"
MONGODB_DB="interview"
MONGODB_COL="questions"

# LLM
GPT_API_KEY="<your-openai-compatible-key>"
GPT_BASE_URL="<your-openai-compatible-base-url>"
ALIYUN_API_KEY="<your-aliyun-key>"
ALIYUN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DOUBAO_API_KEY="<your-doubao-key>"
DOUBAO_BASE_URL="<your-doubao-base-url>"

# Django
# SECRET_KEY 必须是 50+ 字符的高熵随机字符串，否则 JWT 可被伪造。
# 生成示例: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY="<replace-with-50+-char-random-string>"
DEBUG=False
ALLOWED_HOSTS="127.0.0.1,localhost,your-domain.com"

# 可选：日志（settings.py LOGGING）
INTERVIEW_LOG_LEVEL=INFO
# INTERVIEW_LOG_FILE=/var/log/interview.log
